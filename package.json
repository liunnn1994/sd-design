{
  "name": "sd-design-vue-monorepo",
  "private": true,
  "description": "SD Design Vue Monorepo",
  "license": "AGPL-3.0-only",
  "author": "SData FE Team",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "cz": "git-cz",
    "simple-git-hooks": "simple-git-hooks",
    "prepare": "run-s simple-git-hooks",
    "build:tools": "pnpm -F @sd-design/sd-vue-scripts run build",
    "init": "pnpm run build:tools && pnpm i && pnpm -F @sdata/web-vue run init",
    "dev": "pnpm run dev:all",
    "dev:all": "run-p dev:component dev:docs",
    "dev:component": "pnpm --filter @sdata/web-vue run start",
    "dev:docs": "pnpm --filter @sd-design/sd-vue-docs run dev",
    "build": "pnpm run build:all",
    "build:all": "run-s build:tools build:component build:docs",
    "build:docs": "pnpm --filter @sd-design/sd-vue-docs run build",
    "test:screenshot": "pnpm --filter @sdata/web-vue run test:screenshot",
    "build:component": "pnpm --filter @sdata/web-vue run build",
    "format": "oxfmt .",
    "format:all": "pnpm run format",
    "format:check": "oxfmt --check .",
    "clean": "pnpm -r exec rimraf dist node_modules",
    "lint": "pnpm run lint:all",
    "lint:all": "pnpm run lint:code",
    "lint:code": "oxlint . --vue-plugin --import-plugin --node-plugin",
    "lint:ci": "pnpm run lint:all",
    "lint:fix": "oxlint . --vue-plugin --import-plugin --node-plugin --fix",
    "check": "pnpm run check:local",
    "check:local": "run-s lint test",
    "check:ci": "run-s format:check lint:ci test:ci build:ci",
    "test": "pnpm run test:component",
    "test:component": "pnpm --filter @sdata/web-vue run test",
    "test:ci": "pnpm run test:component",
    "test:all": "run-s test:component test:screenshot",
    "format:readme": "oxfmt README.md",
    "format:pkg": "oxfmt package.json",
    "install:deps": "pnpm i",
    "install:ci": "pnpm install --frozen-lockfile",
    "build:ci": "pnpm run build:all",
    "release:check": "run-s check:ci test:screenshot",
    "upgrade:all": "run-s upgrade:audit upgrade:deps upgrade:engines upgrade:browserslist upgrade:skills format:readme format:pkg install:deps upgrade:oxlint",
    "upgrade:browserslist": "node scripts/upgradeBrowserslist.mjs",
    "upgrade:deps": "ncu -u -c 30d -w",
    "upgrade:skills": "pnpx skills update -p -a trae -a claude-code",
    "upgrade:engines": "node scripts/upgradeEngines.mjs",
    "upgrade:oxlint": "node scripts/upgradeOxlint.mjs",
    "upgrade:audit": "pnpm audit --fix --registry=https://registry.npmjs.org"
  },
  "dependencies": {
    "es-toolkit": "^1.45.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "confbox": "^0.2.4",
    "eslint": "^10.2.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "git-cz": "^4.9.0",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^20.0.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.7.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-rational-order": "^0.1.2",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint -e"
