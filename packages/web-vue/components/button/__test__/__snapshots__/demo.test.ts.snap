        </button></div>
      <!---->
      <div class="sd-space-item"><button class="sd-btn sd-btn-dashed sd-btn-shape-square sd-btn-size-medium sd-btn-status-danger" type="button">
          <!--v-if-->Dashed
        </button></div>
      <!---->
      <div class="sd-space-item"><button class="sd-btn sd-btn-outline sd-btn-shape-square sd-btn-size-medium sd-btn-status-danger" type="button">
          <!--v-if-->Outline
        </button></div>
      <!---->
      <div class="sd-space-item"><button class="sd-btn sd-btn-text sd-btn-shape-square sd-btn-size-medium sd-btn-status-danger" type="button">
          <!--v-if-->Text
