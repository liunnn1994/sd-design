// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Image > Should show preview on click 1`] = `
<div class="sd-image sd-image-with-footer-inner"><img class="sd-image-img" src="http://it-does-not-matter.png/">
  <!--v-if-->
  <!--v-if-->
  <!--teleport start-->
  <div class="sd-image-preview" style="z-index: 1001; position: fixed;">
    <transition-stub name="image-fade" appear="false" persisted="true" css="true">
      <div class="sd-image-preview-mask" style=""></div>
    </transition-stub>
    <div tabindex="0" class="sd-image-preview-wrapper">
      <!-- img -->
      <div class="sd-image-preview-img-container" style="transform: scale(1, 1);"><img src="http://it-does-not-matter.png/" class="sd-image-preview-img" style="transform: translate(0px, 0px) rotate(0deg);"></div><!-- loading -->
      <div class="sd-image-preview-loading"><svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" viewBox="0 0 48 48" class="sd-icon sd-icon-loading" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter">
          <path d="M42 24c0 9.941-8.059 18-18 18S6 33.941 6 24 14.059 6 24 6"></path>
        </svg></div><!-- scale value -->
      <transition-stub name="image-fade" appear="false" persisted="false" css="true">
        <!--v-if-->
      </transition-stub><!-- toolbar -->
      <!--v-if-->
      <!-- close btn -->
      <div class="sd-image-preview-close-btn"><svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" viewBox="0 0 48 48" class="sd-icon sd-icon-close" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter">
          <path d="M9.857 9.858 24 24m0 0 14.142 14.142M24 24 38.142 9.858M24 24 9.857 38.142"></path>
        </svg></div><!-- group arrow -->
      <!--v-if-->
    </div>
  </div>
  <!--teleport end-->
</div>
`;
