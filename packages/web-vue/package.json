{
  "name": "@sdata/web-vue",
  "version": "1.3.0",
  "description": "SD Design Vue: A Vue.js 3 UI Library",
  "keywords": [
    "sd",
    "vue"
  ],
  "homepage": "https://sd.design/vue",
  "license": "AGPL-3.0-only",
  "author": "SData FE Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liunnn1994/sd-design.git"
  },
  "files": [
    "es",
    "lib",
    "dist",
    "json"
  ],
  "sideEffects": [
    "dist/*",
    "es/**/style/*",
    "lib/**/style/*",
    "*.less"
  ],
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "unpkg": "dist/sd-vue.min.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "init": "pnpm run build:module",
    "predev": "pnpm run icongen && pnpm run lessgen",
    "dev": "vp run task:dev-component",
    "start": "pnpm run dev",
    "icongen": "vp run gen:icons",
    "lessgen": "vp run gen:less",
    "jsongen": "vp run gen:web-types",
    "build": "pnpm run build:component && pnpm run build:style && pnpm run build:dts && pnpm run jsongen",
    "prebuild:component": "pnpm run icongen && pnpm run lessgen",
    "build:component": "vp run task:build-component",
    "prebuild:module": "pnpm run icongen && pnpm run lessgen",
    "build:module": "vp run task:build-module",
    "prebuild:style": "pnpm run lessgen",
    "build:style": "vp run task:build-style",
    "prebuild:dts": "pnpm run icongen",
    "build:dts": "vp run task:build-dts",
    "dtsgen": "pnpm run build:dts",
    "test": "vp test run",
    "test:update": "vp test run -u",
    "lint-staged": "npx lint-staged"
  },
  "dependencies": {
    "@arco-design/color": "^0.4.0",
    "b-tween": "^0.3.3",
    "b-validate": "^1.5.3",
    "compute-scroll-into-view": "^3.1.1",
    "dayjs": "^1.11.20",
    "number-precision": "^1.6.0",
    "resize-observer-polyfill": "^1.5.1",
    "scroll-into-view-if-needed": "^3.1.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/test-utils": "^2.4.6",
    "clean-css": "^5.3.3",
    "eslint": "^10.2.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.8.0",
    "fast-glob": "^3.3.3",
    "glob": "^13.0.6",
    "jest-serializer-vue": "^3.1.0",
    "jsdom": "^26.1.0",
    "less": "^4.6.4",
    "semantic-release": "^25.0.3",
    "stylelint": "^17.7.0",
    "stylelint-config-rational-order": "^0.1.2",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "svgo": "^4.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plus": "^0.1.16",
    "vitest": "^4.0.7",
    "vue-docgen-api": "4.79.2",
    "vue-tsc": "^3.1.1"
  },
  "peerDependencies": {
    "vue": ">=3.1.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,vue}": [
      "eslint --fix",
      "oxfmt"
    ],
    "*.{less,css}": [
      "stylelint --fix",
      "oxfmt"
    ]
  },
  "vetur": {
    "tags": "json/vetur-tags.json",
    "attributes": "json/vetur-attributes.json"
  },
  "web-types": "json/web-types.json"
}
